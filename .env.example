# daily-digest 환경 변수 예시 — 이 파일을 .env로 복사해 값을 채우세요.
# 파이프라인(npm start)이 이 키로 한국어 번역과 상세 뷰(전문 기반)를 생성합니다.
# 아무 키도 없으면 파이프라인은 원문을 그대로 두고 진행합니다(graceful fallback).

# LLM 프로바이더 API 키 — 아래 중 하나만 설정해도 충분합니다.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=

# 키가 여럿일 때 사용할 프로바이더를 고정(anthropic | openai | grok | gemini).
# 비우면 anthropic → openai → gemini → grok 순으로 첫 키를 사용합니다.
LLM_PROVIDER=

# (선택) 프로바이더별 모델 override — 비우면 기본값 사용.
# ANTHROPIC_MODEL=claude-sonnet-5
# OPENAI_MODEL=gpt-5.5
# XAI_MODEL=grok-4.3
# GEMINI_MODEL=gemini-3.5-flash
